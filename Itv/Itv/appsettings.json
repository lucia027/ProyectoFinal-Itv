{
  "Storage": {
    "Type": "csv"
  },
  "Repository": {
    "Type": "efc",
    "Directory": "data",
    "ConnectionString": "Data Source=data/itv.db",
    "DropData": true,
    "SeedData": true,
    "UseLogicalDelete": false
  },
  "Cache": {
    "Size": 8
  }, 
  "Reports": {
    "Directory": "reports"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": "Debug",
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 5,
          "retainedFileTimeLimit": "5.00:00:00",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{Level:u3}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  }
}