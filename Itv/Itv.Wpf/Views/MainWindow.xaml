<Window x:Class="Itv.Wpf.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Gestión ITV"
        Width="1280"
        Height="760"
        MinWidth="1100"
        MinHeight="680"
        WindowStartupLocation="CenterScreen"
        Background="#EAF3FB"
        FontFamily="Segoe UI">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#0F2F4F" />
        <SolidColorBrush x:Key="PrimaryBrush" Color="#1C6EA4" />
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderSoftBrush" Color="#D7E7F5" />
        <SolidColorBrush x:Key="TextMainBrush" Color="#1C2B39" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#607D97" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D64545" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <Style x:Key="BaseButton" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MenuButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="#153D63" />
            <Setter Property="Height" Value="42" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Background" Value="#EAF3FB" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}" />
        </Style>

        <Style x:Key="SearchButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="0" />
        </Style>

        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FBFDFF" />
            <Setter Property="Foreground" Value="{StaticResource TextMainBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                    <Setter Property="ToolTip"
                            Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="Background" Value="#FBFDFF" />
        </Style>

        <Style x:Key="InputDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="36" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="Background" Value="#FBFDFF" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF5FB" />
            <Setter Property="RowHeight" Value="40" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F7FC" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryDarkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderSoftBrush}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- MENÚ LATERAL -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryDarkBrush}">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,8,0,28">
                    <TextBlock Text="Gestión ITV"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold" />

                    <TextBlock Text="Panel de citas"
                               Foreground="#B8D7ED"
                               FontSize="13"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="1">
                    <TextBlock Text="NAVEGACIÓN"
                               Foreground="#B8D7ED"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />

                    <Button Content="📅  Citas"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding MostrarCitasCommand}" />

                    <Button Content="📊  Informes"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding MostrarInformesCommand}" />

                    <Rectangle Height="1"
                               Fill="#2B5A82"
                               Margin="0,12,0,18" />

                    <Button Content="➕  Crear"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding CitaVm.CrearCitaCommand}" />

                    <Button Content="✏️  Actualizar"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding CitaVm.ActualizarCitaCommand}" />

                    <Button Content="🗑️  Eliminar"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding CitaVm.EliminarCitaCommand}" />

                    <Rectangle Height="1"
                               Fill="#2B5A82"
                               Margin="0,12,0,18" />

                    <Button Content="📥  Importar"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding MostrarImportarCommand}" />

                    <Button Content="📤  Exportar"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding MostrarExportarCommand}" />
                </StackPanel>

                <StackPanel Grid.Row="2">
                    <Button Content="ℹ️  Acerca de"
                            Style="{StaticResource MenuButton}"
                            Command="{Binding AbrirAcercaDeCommand}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENIDO PRINCIPAL -->
        <Grid Grid.Column="1" Margin="26">

            <!-- VISTA CITAS -->
            <Grid Visibility="{Binding IsCitasVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2.1*" />
                    <ColumnDefinition Width="18" />
                    <ColumnDefinition Width="0.95*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="Listado de citas"
                                   Style="{StaticResource SectionTitle}"
                                   Margin="0,0,0,16" />

                        <Border Grid.Row="1"
                                Background="#F5FAFF"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14"
                                Margin="0,0,0,16">

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1.2*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="1.2*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Motor"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,5" />

                                        <ComboBox Style="{StaticResource InputComboBox}"
                                                  ItemsSource="{Binding CitaVm.MotoresFiltroDisponibles}"
                                                  SelectedItem="{Binding CitaVm.MotorFiltroSeleccionado}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Inspección inicio"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,5" />

                                        <DatePicker Style="{StaticResource InputDatePicker}"
                                                    SelectedDate="{Binding CitaVm.FechaInspeccionInicio}" /> 
                                    </StackPanel>

                                    <StackPanel Grid.Column="4">
                                        <TextBlock Text="Inspección fin"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,5" />

                                        <DatePicker Style="{StaticResource InputDatePicker}"
                                                    SelectedDate="{Binding CitaVm.FechaInspeccionFin}" />
                                    </StackPanel>
                                </Grid>

                                <Grid Grid.Row="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.8*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Buscar"
                                                   Style="{StaticResource MutedText}"
                                                   Margin="0,0,0,5" />

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="8" />
                                                <ColumnDefinition Width="38" />
                                            </Grid.ColumnDefinitions>

                                            <TextBox Grid.Column="0"
                                                     Style="{StaticResource InputTextBox}"
                                                     Text="{Binding CitaVm.CampoBusqueda, UpdateSourceTrigger=PropertyChanged}"
                                                     ToolTip="Busca por matrícula, marca, modelo o DNI" />

                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SearchButton}"
                                                    Command="{Binding CitaVm.BuscarCommand}"
                                                    ToolTip="Buscar">
                                                <TextBlock Text="&#xE721;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="White"
                                                           FontSize="15"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>
                                    </StackPanel>

                                    <CheckBox Grid.Column="2"
                                              Content="Ver eliminadas"
                                              IsChecked="{Binding CitaVm.IncluirEliminadas}"
                                              Visibility="{Binding CitaVm.IsBorradoLogico, Converter={StaticResource BoolToVisibility}}"
                                              VerticalAlignment="Bottom"
                                              HorizontalAlignment="Right"
                                              Margin="0,0,0,9" />
                                </Grid>
                            </Grid>
                        </Border>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding CitaVm.Citas}"
                                  SelectedItem="{Binding CitaVm.CitaSeleccionada}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"
                                                    Binding="{Binding Id}"
                                                    SortMemberPath=" Id"
                                                    Width="65" />

                                <DataGridTextColumn Header="Matrícula"
                                                    Binding="{Binding Matricula}"
                                                    SortMemberPath="Matricula"
                                                    Width="100" />

                                <DataGridTextColumn Header="Marca"
                                                    Binding="{Binding Marca}"
                                                    SortMemberPath="Marca"
                                                    Width="100" />

                                <DataGridTextColumn Header="Modelo"
                                                    Binding="{Binding Modelo}"
                                                    SortMemberPath="Modelo"
                                                    Width="100" />

                                <DataGridTextColumn Header="Motor"
                                                    Binding="{Binding Motor}"
                                                    SortMemberPath="Motor"
                                                    Width="100" />

                                <DataGridTextColumn Header="Cilindrada"
                                                    Binding="{Binding Cilindrada}"
                                                    SortMemberPath="Cilindrada"
                                                    Width="100" />

                                <DataGridTextColumn Header="DNI dueño"
                                                    Binding="{Binding DniDueño}"
                                                    SortMemberPath="DniDueño"
                                                    Width="100" />

                                <DataGridTextColumn Header="Matriculación"
                                                    Binding="{Binding FechaMatriculacion, StringFormat={}{0:dd/MM/yyyy}}"
                                                    SortMemberPath="FechaMatriculacion"
                                                    Width="100" />

                                <DataGridTextColumn Header="Inspección"
                                                    Binding="{Binding FechaInspeccion, StringFormat={}{0:dd/MM/yyyy}}"
                                                    SortMemberPath="FechaInspeccion"
                                                    Width="100" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="3"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,16,0,0">

                            <Button Content="Primera"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CitaVm.PrimeraPaginaCommand}"
                                    Margin="0,0,8,0" />

                            <Button Content="Anterior"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CitaVm.PaginaAnteriorCommand}"
                                    Margin="0,0,8,0" />

                            <Border Background="#F1F7FC"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="12,0"
                                    Height="38"
                                    Margin="0,0,8,0">

                                <TextBlock Text="{Binding CitaVm.TextoPaginaActual}"
                                           Foreground="{StaticResource PrimaryDarkBrush}"
                                           FontWeight="SemiBold" />
                            </Border>

                            <Button Content="Siguiente"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CitaVm.PaginaSiguienteCommand}"
                                    Margin="0,0,8,0" />

                            <Button Content="Última"
                                    Style="{StaticResource SecondaryButton}"
                                    Command="{Binding CitaVm.UltimaPaginaCommand}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="{Binding CitaVm.TituloFormulario}"
                                       Style="{StaticResource SectionTitle}"
                                       Margin="0,0,0,6" />

                            <TextBlock Text="{Binding CitaVm.DescripcionFormulario}"
                                       Style="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,18" />

                            <TextBlock Text="Matrícula" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource InputTextBox}"
                                     Text="{Binding CitaVm.Form.Matricula, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Marca" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource InputTextBox}"
                                     Text="{Binding CitaVm.Form.Marca, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Modelo" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource InputTextBox}"
                                     Text="{Binding CitaVm.Form.Modelo, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Cilindrada" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource InputTextBox}"
                                     Text="{Binding CitaVm.Form.Cilindrada, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Tipo de motor" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <ComboBox Style="{StaticResource InputComboBox}"
                                      ItemsSource="{Binding CitaVm.MotoresDisponibles}"
                                      SelectedItem="{Binding CitaVm.Form.Motor, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                      Margin="0,0,0,12" />

                            <TextBlock Text="DNI dueño" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <TextBox Style="{StaticResource InputTextBox}"
                                     Text="{Binding CitaVm.Form.DniDueño, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                     Margin="0,0,0,12" />

                            <TextBlock Text="Fecha inspección" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <DatePicker Style="{StaticResource InputDatePicker}"
                                        SelectedDate="{Binding CitaVm.Form.FechaInspeccion, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                        Margin="0,0,0,12" />

                            <TextBlock Text="Fecha matriculación" Style="{StaticResource MutedText}" Margin="0,0,0,5" />
                            <DatePicker Style="{StaticResource InputDatePicker}"
                                        SelectedDate="{Binding CitaVm.Form.FechaMatriculacion, UpdateSourceTrigger=PropertyChanged, ValidatesOnDataErrors=True, NotifyOnValidationError=True}"
                                        Margin="0,0,0,18" />

                            <Button Content="Guardar"
                                    Style="{StaticResource BaseButton}"
                                    Command="{Binding CitaVm.GuardarCommand}"
                                    IsEnabled="{Binding CitaVm.Form.IsValid}" />
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
            
            <!-- VISTA INFORMES -->
            <Grid Visibility="{Binding IsInformesVisible, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="Informes"
                                   Style="{StaticResource SectionTitle}"
                                   FontSize="28"
                                   Margin="0,0,0,8" />

                        <TextBlock Text="Selecciona el formato en el que quieres generar el informe de citas."
                                   Style="{StaticResource MutedText}"
                                   Margin="0,0,0,24" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="#F5FAFF"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20">

                                <StackPanel>
                                    <TextBlock Text="Generar informe HTML"
                                               Style="{StaticResource SectionTitle}"
                                               FontSize="20"
                                               Margin="0,0,0,8" />

                                    <TextBlock Text="Crea el informe en formato HTML con el diseño azul del proyecto."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,22" />

                                    <Button Content="Generar HTML"
                                            Style="{StaticResource BaseButton}"
                                            Command="{Binding InformeVm.GenerarInformeHtmlCommand}" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2"
                                    Background="#F5FAFF"
                                    BorderBrush="{StaticResource BorderSoftBrush}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    Padding="20">

                                <StackPanel>
                                    <TextBlock Text="Generar informe PDF"
                                               Style="{StaticResource SectionTitle}"
                                               FontSize="20"
                                               Margin="0,0,0,8" />

                                    <TextBlock Text="Crea el informe en formato PDF para guardarlo o entregarlo."
                                               Style="{StaticResource MutedText}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,22" />

                                    <Button Content="Generar PDF"
                                            Style="{StaticResource BaseButton}"
                                            Command="{Binding InformeVm.GenerarInformePdfCommand}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- VISTA IMPORTAR -->
            <Grid Visibility="{Binding IsImportarVisible, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
            
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Importar datos"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="28"
                                       Margin="0,0,0,8" />
            
                            <TextBlock Text="La importación usará el formato configurado en appsettings.json."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,24" />
                        </StackPanel>
            
                        <Border Grid.Row="1"
                                Background="#F5FAFF"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="24"
                                Width="560"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
            
                            <StackPanel>
                                <TextBlock Text="Formato configurado"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,5" />
            
                                <TextBlock Text="{Binding ImportExportVm.FormatoActual}"
                                           Style="{StaticResource SectionTitle}"
                                           FontSize="24"
                                           Margin="0,0,0,10" />
            
                                <TextBlock Text="{Binding ImportExportVm.DescripcionFormatoActual}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,22" />
            
                                <CheckBox Content="Sustituir datos actuales antes de importar"
                                          IsChecked="{Binding ImportExportVm.SustituirDatos}"
                                          Margin="0,0,0,22" />
            
                                <Button Content="Importar datos"
                                        Style="{StaticResource BaseButton}"
                                        Command="{Binding ImportExportVm.ImportarCommand}"
                                        Margin="0,0,0,14" />
            
                                <TextBlock Text="{Binding ImportExportVm.StatusMessage}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            
            <!-- VISTA EXPORTAR -->
            <Grid Visibility="{Binding IsExportarVisible, Converter={StaticResource BoolToVisibility}}">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
            
                        <StackPanel Grid.Row="0">
                            <TextBlock Text="Exportar datos"
                                       Style="{StaticResource SectionTitle}"
                                       FontSize="28"
                                       Margin="0,0,0,8" />
            
                            <TextBlock Text="La exportación usará el formato configurado en appsettings.json."
                                       Style="{StaticResource MutedText}"
                                       Margin="0,0,0,24" />
                        </StackPanel>
            
                        <Border Grid.Row="1"
                                Background="#F5FAFF"
                                BorderBrush="{StaticResource BorderSoftBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="24"
                                Width="560"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top">
            
                            <StackPanel>
                                <TextBlock Text="Formato configurado"
                                           Style="{StaticResource MutedText}"
                                           Margin="0,0,0,5" />
            
                                <TextBlock Text="{Binding ImportExportVm.FormatoActual}"
                                           Style="{StaticResource SectionTitle}"
                                           FontSize="24"
                                           Margin="0,0,0,10" />
            
                                <TextBlock Text="{Binding ImportExportVm.DescripcionFormatoActual}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,22" />
            
                                <Button Content="Exportar datos"
                                        Style="{StaticResource BaseButton}"
                                        Command="{Binding ImportExportVm.ExportarCommand}"
                                        Margin="0,0,0,14" />
            
                                <TextBlock Text="{Binding ImportExportVm.StatusMessage}"
                                           Style="{StaticResource MutedText}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>